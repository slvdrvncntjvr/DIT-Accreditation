---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="SDG Alignment">
  <div class="mb-8">
    <span class="badge badge-gold mb-3">Pillar</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">SDG Alignment</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      How BSIT program activities contribute to the United Nations Sustainable Development Goals 
      through digital inclusion, quality education, and community-centered technology.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <article class="card p-5 border-l-4 border-l-[#4c9f38]">
      <p class="text-xs font-bold text-[#4c9f38] uppercase tracking-wide">SDG 4</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Quality Education</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Outcomes-based curriculum, accessible instruction, and continuous faculty development.
      </p>
    </article>
    <article class="card p-5 border-l-4 border-l-[#fd6925]">
      <p class="text-xs font-bold text-[#fd6925] uppercase tracking-wide">SDG 9</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Industry, Innovation & Infrastructure</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Student-built systems, applied research, and technology solutions for organizations.
      </p>
    </article>
    <article class="card p-5 border-l-4 border-l-[#dd1367]">
      <p class="text-xs font-bold text-[#dd1367] uppercase tracking-wide">SDG 10</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Reduced Inequalities</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Digital literacy programs for underserved communities and accessible education delivery.
      </p>
    </article>
    <article class="card p-5 border-l-4 border-l-[#fd9d24]">
      <p class="text-xs font-bold text-[#fd9d24] uppercase tracking-wide">SDG 11</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Sustainable Cities</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Community mapping systems, incident dashboards, and local governance tools.
      </p>
    </article>
    <article class="card p-5 border-l-4 border-l-[#00689d]">
      <p class="text-xs font-bold text-[#00689d] uppercase tracking-wide">SDG 17</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Partnerships for the Goals</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Industry linkages, international collaborations, and multi-sector extension partnerships.
      </p>
    </article>
    <article class="card p-5 border-l-4 border-l-[#19486a]">
      <p class="text-xs font-bold text-[#19486a] uppercase tracking-wide">SDG 8</p>
      <h3 class="mt-1 text-sm font-semibold text-[var(--neutral-900)]">Decent Work & Economic Growth</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Graduate employability, industry-ready skills, and practicum placements.
      </p>
    </article>
  </section>
</SiteLayout>

---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Planning and QA">
  <div class="mb-8">
    <span class="badge badge-gold mb-3">Pillar</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Planning & Quality Assurance</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      Strategic planning and continuous improvement cycles that drive the program toward 
      measurable goals — monitored, evaluated, and acted upon.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <!-- Planning roadmap -->
  <section>
    <h2 class="section-heading">Program Goals & Targets</h2>
    <p class="section-subheading">Key milestones the BSIT program is working toward.</p>
    <div class="mt-5 space-y-3">
      <article class="card p-5 border-l-4 border-l-[var(--gold-500)]">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-sm font-semibold text-[var(--neutral-900)]">Curriculum Alignment with Industry 4.0</h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)]">Integrate AI/ML, cloud, and IoT topics across core courses by AY 2026-2027.</p>
          </div>
          <span class="badge badge-gold">Target 2027</span>
        </div>
      </article>
      <article class="card p-5 border-l-4 border-l-[var(--gold-500)]">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-sm font-semibold text-[var(--neutral-900)]">Research Output Growth</h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)]">Increase faculty-led publications to 10+ per year with student co-authors.</p>
          </div>
          <span class="badge badge-gold">Target 2026</span>
        </div>
      </article>
      <article class="card p-5 border-l-4 border-l-[var(--gold-500)]">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-sm font-semibold text-[var(--neutral-900)]">Level IV Accreditation</h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)]">Achieve AACCUP Level IV status through sustained excellence across all areas.</p>
          </div>
          <span class="badge badge-maroon">Target 2028</span>
        </div>
      </article>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="section-heading">Quality Assurance Mechanisms</h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <article class="card p-6">
        <h3 class="text-lg font-semibold text-[var(--neutral-900)]">Internal Review</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">
          Annual program review, faculty performance evaluation, and 
          course-level outcome assessment to identify improvement areas.
        </p>
      </article>
      <article class="card p-6">
        <h3 class="text-lg font-semibold text-[var(--neutral-900)]">Stakeholder Feedback</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">
          Graduate tracer studies, employer surveys, and industry advisory 
          consultations that inform curriculum and delivery improvements.
        </p>
      </article>
    </div>
  </section>
</SiteLayout>

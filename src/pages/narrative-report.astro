---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Narrative Report">
  <div class="mb-8">
    <span class="badge badge-maroon mb-3">Core Document</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Narrative Report</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      A comprehensive summary of the BSIT program's progress — from enrollment patterns 
      through instruction, research, extension, and graduate outcomes.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <section class="space-y-4">
    <article class="card p-6 border-l-4 border-l-[var(--maroon-600)]">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Instruction</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Summary of teaching delivery, assessment outcomes, and instructional innovations 
        over the accreditation period. Replace with official narrative content.
      </p>
    </article>

    <article class="card p-6 border-l-4 border-l-[var(--gold-500)]">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Research</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Faculty and student research outputs, publications, awards, and deployments 
        demonstrating the program's research culture.
      </p>
    </article>

    <article class="card p-6 border-l-4 border-l-[var(--maroon-500)]">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Extension</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Community engagement activities, beneficiary outcomes, and sustainable 
        technology interventions delivered by the department.
      </p>
    </article>

    <article class="card p-6 border-l-4 border-l-[var(--gold-400)]">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Partnerships & Linkages</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Industry, academic, and international partnerships that support program 
        delivery and graduate employment.
      </p>
    </article>

    <article class="card p-6 border-l-4 border-l-[var(--neutral-400)]">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Graduate Outcomes</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Employability data, tracer study results, and notable alumni achievements 
        that evidence program effectiveness.
      </p>
    </article>
  </section>
</SiteLayout>

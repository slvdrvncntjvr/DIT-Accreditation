---
import SiteLayout from "../layouts/SiteLayout.astro";
import { updateGuide, videoEmbeds } from "../data/embeds";
---

<SiteLayout title="Media and Downloads">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Media & Downloads</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      Videos, photos, and downloadable materials used during accreditation review.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <!-- Videos -->
  <section>
    <h2 class="section-heading">Videos</h2>
    <p class="section-subheading">Program overview, highlights, and documentation.</p>
    <div class="mt-5 grid gap-5 md:grid-cols-2">
      {
        videoEmbeds.map((item) => (
          <article class="card overflow-hidden">
            <div class="aspect-video border-b border-[var(--line)]">
              <iframe
                src={item.url}
                title={item.title}
                loading="lazy"
                class="h-full w-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-semibold text-[var(--neutral-900)]">{item.title}</h3>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Photo gallery placeholder -->
  <section class="mt-10">
    <h2 class="section-heading">Photo Gallery</h2>
    <p class="section-subheading">Our students and graduates in action.</p>
    <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Update guide for maintainers -->
  <section class="mt-10">
    <div class="card p-6 bg-[var(--neutral-100)] border-[var(--line-subtle)]">
      <h2 class="text-base font-semibold text-[var(--neutral-900)]">How to update media links</h2>
      <ol class="mt-3 list-decimal space-y-1.5 pl-5 text-sm text-[var(--text-secondary)]">
        {updateGuide.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>
</SiteLayout>

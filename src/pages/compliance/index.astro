---
import SiteLayout from "../../layouts/SiteLayout.astro";
import StickySectionToc from "../../components/StickySectionToc";
import { complianceAreas } from "../../data/content";

const sections = complianceAreas.map((label, index) => ({
  id: `area-${index + 1}`,
  label,
}));
---

<SiteLayout title="Compliance Report">
  <div class="mb-8">
    <span class="badge badge-maroon mb-3">Core Document</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Compliance Report</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      Area-based evidence organized for AACCUP review. Each area contains narrative, 
      linked supporting documents, and assessment indicators.
    </p>
  </div>

  <!-- Certificate of Authenticity -->
  <div class="mb-6 rounded-xl border border-[var(--gold-300)] bg-[var(--gold-50)] px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 text-[var(--gold-600)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
      </svg>
      <span class="text-sm font-medium text-[var(--neutral-900)]">All documents uploaded to this site are certified authentic and verified.</span>
    </div>
    <a href="#" class="text-xs font-medium text-[var(--gold-600)] no-underline hover:underline shrink-0">View Certificate →</a>
  </div>

  <div class="grid gap-6 md:grid-cols-[280px_1fr]">
    <StickySectionToc client:load sections={sections} />
    <div class="space-y-4">
      {
        sections.map((section, index) => (
          <article id={section.id} class="card card-interactive scroll-mt-28 p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-lg font-semibold text-[var(--neutral-900)]">{section.label}</h2>
                <p class="mt-2 text-sm text-[var(--text-secondary)]">
                  Narrative summary and evidence index for {section.label.toLowerCase()}.
                </p>
              </div>
              <span class="shrink-0 flex h-8 w-8 items-center justify-center rounded-full bg-[var(--neutral-100)] text-xs font-bold text-[var(--neutral-600)]">
                {String(index + 1).padStart(2, '0')}
              </span>
            </div>
            <a
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--brand)] no-underline hover:underline"
              href={`/compliance/area-${index + 1}`}
            >
              Open area page
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</SiteLayout>

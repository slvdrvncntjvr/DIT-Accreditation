---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Internationalization">
  <div class="mb-8">
    <span class="badge badge-gold mb-3">Pillar</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Internationalization</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      Global collaborations, cross-border academic partnerships, and international exposure 
      opportunities that position BSIT students and faculty in the wider IT ecosystem.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <section class="grid gap-4 md:grid-cols-2">
    <article class="card card-accent-gold p-6">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">International Partnerships</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Memoranda of understanding, joint programs, and collaborative research 
        with institutions outside the Philippines.
      </p>
    </article>
    <article class="card p-6">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Faculty & Student Mobility</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Exchange opportunities, international conferences attended, and 
        visiting scholars hosted by the department.
      </p>
    </article>
  </section>

  <section class="mt-8">
    <h2 class="section-heading">Global Engagements</h2>
    <p class="section-subheading">Conferences, webinars, and collaborative projects with international reach.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
        <div class="p-4">
          <p class="text-sm font-medium text-[var(--neutral-900)]">International Conference Participation</p>
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
        <div class="p-4">
          <p class="text-sm font-medium text-[var(--neutral-900)]">Cross-border Webinar Series</p>
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo placeholder</span>
        </div>
        <div class="p-4">
          <p class="text-sm font-medium text-[var(--neutral-900)]">MOU Signing Ceremony</p>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

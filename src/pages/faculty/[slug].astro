---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { facultyMembers } from "../../data/content";

export function getStaticPaths() {
  return facultyMembers.map((member) => ({
    params: { slug: member.slug },
    props: { member },
  }));
}

interface Member {
  slug: string;
  name: string;
  role: string;
  expertise: string;
  email: string;
  summary: string;
}

const { member } = Astro.props as { member: Member };
---

<SiteLayout title={`${member.name} | Faculty`}>
  <a href="/faculty" class="inline-flex items-center gap-1 text-sm text-[var(--text-muted)] no-underline hover:text-[var(--brand)] mb-6">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to faculty
  </a>

  <article class="card p-6 md:p-8">
    <div class="flex flex-col sm:flex-row sm:items-start gap-5">
      <!-- Avatar -->
      <div class="w-20 h-20 rounded-full bg-[var(--maroon-100)] flex items-center justify-center shrink-0">
        <span class="text-2xl font-bold text-[var(--maroon-600)]">
          {member.name.split(' ').filter(n => n.length > 2).slice(0, 2).map(n => n[0]).join('')}
        </span>
      </div>

      <div class="flex-1">
        <h1 class="text-2xl font-bold text-[var(--neutral-900)] md:text-3xl">{member.name}</h1>
        <p class="mt-1 text-base text-[var(--gold-600)] font-medium">{member.role}</p>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">{member.expertise}</p>
      </div>
    </div>

    <div class="divider-network"><span class="node"></span></div>

    <div class="grid gap-6 md:grid-cols-2">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">About</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{member.summary}</p>
      </div>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">Contact</h2>
        <a href={`mailto:${member.email}`} class="text-sm">{member.email}</a>
      </div>
    </div>
  </article>
</SiteLayout>

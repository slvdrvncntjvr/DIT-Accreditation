---
import SiteLayout from "../layouts/SiteLayout.astro";
import { researchProjects } from "../data/content";
---

<SiteLayout title="Research">
  <!-- Page header -->
  <div class="mb-8">
    <span class="badge badge-gold mb-3">Pillar</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Research</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      DIT research is project-led and solutions-oriented — student and faculty work that addresses 
      real educational and community problems using technology.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <!-- Impact stats -->
  <section class="grid gap-4 sm:grid-cols-4 mb-8" data-reveal="up" data-stagger>
    <div class="card p-5 text-center">
      <p class="stat-value">15+</p>
      <p class="stat-label">Published Papers</p>
    </div>
    <div class="card p-5 text-center">
      <p class="stat-value">8</p>
      <p class="stat-label">Deployed Systems</p>
    </div>
    <div class="card p-5 text-center">
      <p class="stat-value">5</p>
      <p class="stat-label">Competition Awards</p>
    </div>
    <div class="card p-5 text-center">
      <p class="stat-value">3</p>
      <p class="stat-label">Funded Grants</p>
    </div>
  </section>

  <!-- Featured projects -->
  <section data-reveal="up">
    <h2 class="section-heading">Featured Projects</h2>
    <p class="section-subheading">Selected research outputs with real-world impact.</p>
    <div class="mt-5 space-y-4">
      {
        researchProjects.map((project) => (
          <article class="card card-interactive p-6">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-[var(--neutral-900)]">{project.title}</h3>
                <p class="mt-2 text-sm text-[var(--text-secondary)]">{project.problem}</p>
                <p class="mt-3 text-sm text-[var(--text-secondary)]">
                  <strong class="text-[var(--neutral-700)]">Outcome:</strong> {project.outcome}
                </p>
              </div>
              <div class="shrink-0">
                <span class="inline-block rounded-md bg-[var(--neutral-100)] px-3 py-1.5 text-xs font-mono text-[var(--neutral-700)]">
                  {project.stack}
                </span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Research in action -->
  <section class="mt-10" data-reveal="up">
    <h2 class="section-heading">Our Research in Action</h2>
    <p class="section-subheading">Faculty and student researchers presenting, deploying, and testing their work.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo/video placeholder</span>
        </div>
        <div class="p-4">
          <p class="text-sm font-medium text-[var(--neutral-900)]">Research Colloquium 2025</p>
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="aspect-video bg-[var(--neutral-200)] flex items-center justify-center">
          <span class="text-xs text-[var(--text-muted)]">Photo/video placeholder</span>
        </div>
        <div class="p-4">
          <p class="text-sm font-medium text-[var(--neutral-900)]">National IT Competition</p>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

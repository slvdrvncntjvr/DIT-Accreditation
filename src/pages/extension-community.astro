---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Extension and Community">
  <div class="mb-8">
    <span class="badge badge-gold mb-3">Pillar</span>
    <h1 class="text-3xl font-bold text-[var(--neutral-900)] md:text-4xl tracking-tight">Extension & Community</h1>
    <p class="mt-3 text-base text-[var(--text-secondary)] max-w-3xl">
      The department applies technology expertise to extension initiatives — building digital 
      capacity in partner communities and delivering sustainable solutions beyond the campus.
    </p>
  </div>

  <div class="divider-network"><span class="node"></span></div>

  <section class="grid gap-4 md:grid-cols-2">
    <article class="card card-accent-gold p-6">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Community Programs</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        ICT literacy workshops, system deployments for barangay offices, and digital skills 
        training for out-of-school youth and cooperative members.
      </p>
    </article>
    <article class="card p-6">
      <h2 class="text-lg font-semibold text-[var(--neutral-900)]">Partner Organizations</h2>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">
        Collaborations with local government units, NGOs, and institutional partners 
        for sustained community impact through technology interventions.
      </p>
    </article>
  </section>

  <section class="mt-8">
    <h2 class="section-heading">Impact Evidence</h2>
    <p class="section-subheading">Measurable outcomes from extension activities.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-3">
      <div class="card p-5 text-center">
        <p class="stat-value">12</p>
        <p class="stat-label">Partner Communities</p>
      </div>
      <div class="card p-5 text-center">
        <p class="stat-value">500+</p>
        <p class="stat-label">Beneficiaries</p>
      </div>
      <div class="card p-5 text-center">
        <p class="stat-value">6</p>
        <p class="stat-label">Systems Deployed</p>
      </div>
    </div>
  </section>
</SiteLayout>

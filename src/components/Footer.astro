---
import { siteMeta } from "../data/site";
---

<footer class="mt-20 border-t border-[var(--line)] bg-white">
  <div class="container-shell py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Identity -->
      <div>
        <div class="flex items-center gap-2.5 mb-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--maroon-600)] ring-2 ring-[var(--gold-500)]">
            <span class="text-[0.625rem] font-bold text-white leading-none">DIT</span>
          </div>
          <p class="text-sm font-semibold text-[var(--neutral-900)]">{siteMeta.department}</p>
        </div>
        <p class="text-sm text-[var(--text-secondary)]">{siteMeta.program}</p>
        <p class="text-sm text-[var(--text-muted)] mt-1">{siteMeta.institution}</p>
        <p class="text-sm text-[var(--text-muted)]">{siteMeta.campus}</p>
      </div>

      <!-- Quick links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-3">Quick Links</p>
        <nav class="grid gap-1.5">
          <a href="/compliance" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">Compliance Report</a>
          <a href="/narrative-report" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">Narrative Report</a>
          <a href="/media-downloads" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">Media & Downloads</a>
          <a href="/faculty" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">Faculty</a>
        </nav>
      </div>

      <!-- Online Services -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-3">Online Services</p>
        <nav class="grid gap-1.5">
          <a href="https://www.pup.edu.ph/" target="_blank" rel="noopener" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">PUP Website ↗</a>
          <a href="https://pupsinta.freshservice.com/support/home" target="_blank" rel="noopener" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">PUP SINTA ↗</a>
          <a href="https://sis1.pup.edu.ph/student/" target="_blank" rel="noopener" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">SIS for Students ↗</a>
          <a href="https://iapply.pup.edu.ph/signin" target="_blank" rel="noopener" class="text-sm text-[var(--text-secondary)] no-underline hover:text-[var(--brand)]">PUP iApply ↗</a>
        </nav>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-8 pt-6 border-t border-[var(--line-subtle)] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-xs text-[var(--text-muted)]">
        © 2026 {siteMeta.department} · College of Computer and Information Sciences · PUP
      </p>
      <div class="flex items-center gap-3">
        <a href="https://www.facebook.com/" target="_blank" rel="noopener" class="text-[var(--text-muted)] hover:text-[var(--brand)] transition-colors" aria-label="Facebook">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/" target="_blank" rel="noopener" class="text-[var(--text-muted)] hover:text-[var(--brand)] transition-colors" aria-label="YouTube">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="#fff" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
